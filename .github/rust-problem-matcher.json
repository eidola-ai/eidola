{
  "problemMatcher": [
    {
      "owner": "rust",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^(warning|error)(\\[\\w+\\])?: (.+)$",
          "severity": 1,
          "message": 3
        },
        {
          "regexp": "^\\s+--> (.+):(\\d+):(\\d+)$",
          "file": 1,
          "line": 2,
          "column": 3
        }
      ]
    }
  ]
}
