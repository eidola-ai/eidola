{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eidola.ai/schema/attestation-v1.0.0.json",
  "title": "Eidola Human Release Attestation",
  "description": "A sworn statement by a release engineer covering a specific release. Signed (Sigstore bundle) by a hardware-resident key whose fingerprint is in the client's TRUSTED_ATTESTANT_FINGERPRINTS. The claims block is keyed by a flat set of snake_case names matching attestation-templates-v1.0.0.json; the verifier re-renders each template and rejects unless the statement equals the rendered output character-for-character.",
  "type": "object",
  "required": [
    "schema_version",
    "release_version",
    "git_commit",
    "artifact_manifest_sha256",
    "attestant",
    "attested_at",
    "attestant_statement",
    "claims"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "release_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[0-9A-Za-z.-]+)?$"
    },
    "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "previous_release_git_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "artifact_manifest_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "privacy_guarantees_doc_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "attestant": {
      "type": "object",
      "required": ["id", "name", "key_fingerprint_sha256", "jurisdiction"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string", "minLength": 1 },
        "key_fingerprint_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "jurisdiction": { "type": "string", "minLength": 1 }
      }
    },
    "attested_at": { "type": "string", "format": "date-time" },
    "attestant_statement": { "type": "string", "minLength": 1 },
    "claims": {
      "type": "object",
      "required": [
        "no_compulsion",
        "no_coercion",
        "signing_freely",
        "manifest_reproduced",
        "diff_reviewed",
        "no_known_privacy_weakening",
        "no_known_backdoor"
      ],
      "additionalProperties": false,
      "properties": {
        "no_compulsion": { "$ref": "#/$defs/claim_no_fields" },
        "no_coercion": { "$ref": "#/$defs/claim_no_fields" },
        "signing_freely": { "$ref": "#/$defs/claim_no_fields" },
        "manifest_reproduced": { "$ref": "#/$defs/claim_with_fields" },
        "diff_reviewed": { "$ref": "#/$defs/claim_with_fields" },
        "no_known_privacy_weakening": {
          "$ref": "#/$defs/claim_with_fields"
        },
        "no_known_backdoor": { "$ref": "#/$defs/claim_no_fields" }
      }
    }
  },
  "$defs": {
    "claim_no_fields": {
      "type": "object",
      "required": ["statement"],
      "additionalProperties": false,
      "properties": {
        "statement": { "type": "string", "minLength": 1 }
      }
    },
    "claim_with_fields": {
      "type": "object",
      "required": ["statement", "fields"],
      "additionalProperties": false,
      "properties": {
        "statement": { "type": "string", "minLength": 1 },
        "fields": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
