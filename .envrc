# Build the pinned Rust-based dev tools (anchored in crates/devtools) and
# put them on PATH. This is the only thing standing between a `cargo` +
# `direnv` checkout and a working dev environment — `just`, `rumdl`, etc.
# come from here, so no separate `brew install just` is needed.
cargo build --quiet -p rumdl -p just
PATH_add target/debug
