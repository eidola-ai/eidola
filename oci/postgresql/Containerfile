# syntax=docker/dockerfile:1@sha256:a7f5ec8c4a35a7f8cd9e6e413f59fd1bfd33f8b623c26981c684f5065dfe3044

# ── base ───────────────────────────────────────────────────────────────────────
# Pin digests for all StageX package dependencies.

FROM stagex/user-postgresql@sha256:4b6d68746a0896735331c4688d2890c2418e6a187e4c01936491dd40dfc747c1 AS pkg-postgresql
FROM stagex/core-busybox@sha256:d608daa946e4799cf28b105aba461db00187657bd55ea7c2935ff11dac237e27 AS pkg-busybox
FROM stagex/core-musl@sha256:816a6e097544c23386c95c8614e358ace7c5026c3f53b7b9353b84cbb4ed0096 AS pkg-musl
FROM stagex/core-zlib@sha256:130afab57ac8e9a9eb1e0c6e2c91758a67f731634d3cdb45ae04ea0534cc3930 AS pkg-zlib
FROM stagex/core-openssl@sha256:decacae13674bebbeaef3ce79c5d1159ae8495f272f8fa7e5db660c84ab37d1d AS pkg-openssl
FROM stagex/core-libcxx@sha256:733ddf3bf6a47ba39578bec31d30804db134fa72482e8dbf4fcf288788d8a5b4 AS pkg-libcxx
FROM stagex/core-libcxxabi@sha256:88e66348a0eb2b1c0a321aaac138aef4ccc4bbd13a16ffd1de0231d5506f66b3 AS pkg-libcxxabi
FROM stagex/core-libunwind@sha256:c76fcc66148b19230247b7cdba06040dbe2f47aa19d7a4be4d430db15d47e4b8 AS pkg-libunwind
FROM stagex/core-icu@sha256:7ebe433368a5a520a3676021c49311dedc0bb055dc22fb65b9bcb09cc7efce88 AS pkg-icu
FROM stagex/core-ncurses@sha256:080694dbb4da85bb43e0772f3d42dc4a396e77b8e047a5020b9c266e9bd18212 AS pkg-ncurses
FROM stagex/core-readline@sha256:3578d7ddb18577b28dd7af029033265fd2e7b0b5cd6c700e38311f3b6cec482f AS pkg-readline
FROM stagex/core-libxml2@sha256:b5a12ac859b6bde54c4b7d9b620abe19d1471d500be06c9b446741e56d98638d AS pkg-libxml2

# ── fetch ──────────────────────────────────────────────────────────────────────
# (no-op: all dependencies are pre-built StageX packages pinned above)

# ── build ──────────────────────────────────────────────────────────────────────
# (no-op: using pre-built packages, no compilation needed)

# ── install ────────────────────────────────────────────────────────────────────
# Assemble filesystem from StageX packages (COPY only, no RUN needed).

FROM scratch AS install

COPY --from=pkg-busybox . /
COPY --from=pkg-musl . /
COPY --from=pkg-zlib . /
COPY --from=pkg-openssl . /
COPY --from=pkg-libcxx . /
COPY --from=pkg-libcxxabi . /
COPY --from=pkg-libunwind . /
COPY --from=pkg-icu . /
COPY --from=pkg-ncurses . /
COPY --from=pkg-readline . /
COPY --from=pkg-libxml2 . /
COPY --from=pkg-postgresql . /
COPY --chmod=755 oci/postgresql/entrypoint.sh /entrypoint.sh

# ── dirs ──────────────────────────────────────────────────────────────────────
# Create runtime directories owned by uid 1000 using a disposable stage.
# We COPY the resulting directory tree into the final image instead of using
# RUN, because RUN layers capture the full overlayfs diff which can include
# host-specific artifacts (e.g. Rosetta translation caches on Docker Desktop)
# that break cross-environment reproducibility.

FROM install AS dirs

RUN --network=none mkdir -p /dirs/var/lib/postgresql/data /dirs/run/postgresql /dirs/docker-entrypoint-initdb.d && \
    chown -R 1000:1000 /dirs

# ── package ────────────────────────────────────────────────────────────────────

FROM scratch AS package

COPY --from=install / /
COPY --from=dirs /dirs/ /

# StageX core-readline is missing a DT_NEEDED for ncurses, so termcap symbols
# (tputs, tgetent, etc.) aren't found by the dynamic linker.
ENV LD_PRELOAD=/lib/libncursesw.so.6
ENV PGDATA=/var/lib/postgresql/data
EXPOSE 5432
USER 1000:1000
ENTRYPOINT ["/entrypoint.sh"]
