# syntax=docker/dockerfile:1@sha256:a7f5ec8c4a35a7f8cd9e6e413f59fd1bfd33f8b623c26981c684f5065dfe3044

FROM rust:1-slim AS fetch
WORKDIR /src
COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
COPY --parents apps/*/Cargo.toml crates/*/Cargo.toml ./
# Stub source files so cargo can resolve all workspace members.
RUN find . -name Cargo.toml -not -path ./Cargo.toml | while read -r manifest; do \
      dir="$(dirname "$manifest")/src"; mkdir -p "$dir"; \
      touch "$dir/lib.rs"; \
      if grep -q '^\[\[bin\]\]' "$manifest"; then echo 'fn main(){}' > "$dir/main.rs"; fi; \
    done
RUN cargo fetch --locked

FROM fetch AS build
COPY apps/ ./apps/
COPY crates/ ./crates/
RUN --mount=type=cache,target=/src/target \
    cargo build --release -p tinfoil-shim-mock \
    && install -D target/release/tinfoil-shim-mock /out/tinfoil-shim-mock

FROM debian:bookworm-slim
WORKDIR /src
COPY --from=build /out/tinfoil-shim-mock /usr/local/bin/
EXPOSE 8443
ENTRYPOINT ["tinfoil-shim-mock"]
