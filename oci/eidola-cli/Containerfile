# syntax=docker/dockerfile:1@sha256:a7f5ec8c4a35a7f8cd9e6e413f59fd1bfd33f8b623c26981c684f5065dfe3044

# ── base ───────────────────────────────────────────────────────────────────────
# Environment variables, pinned toolchain digest.
FROM stagex/pallet-rust@sha256:2fbe7b164dd92edb9c1096152f6d27592d8a69b1b8eb2fc907b5fadea7d11668 AS base

ARG CARGO_PROFILE=release

ENV TARGET=x86_64-unknown-linux-musl
ENV SOURCE_DATE_EPOCH=0
ENV CARGO_INCREMENTAL=0
ENV ZERO_AR_DATE=1
ENV RUSTFLAGS="-C target-feature=+crt-static -C debuginfo=0 -C target-cpu=generic"

WORKDIR /src

# ── fetch ──────────────────────────────────────────────────────────────────────
# Copy only manifests and create stub source files so cargo can resolve the
# workspace. This layer is only invalidated when dependencies change, not on
# every source edit. Dependencies are fetched and pre-compiled, with all
# artifacts baked into the layer (no cache mounts) so they persist via
# BuildKit's layer cache across CI runs.
FROM base AS fetch

COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
COPY --parents apps/*/Cargo.toml crates/*/Cargo.toml ./

# Stub source files so cargo can resolve all workspace members.
# Creates both lib.rs and main.rs (for [[bin]] crates) so that cargo can
# resolve intra-workspace library dependencies during fetch.
RUN find . -name Cargo.toml -not -path ./Cargo.toml | while read -r manifest; do \
      dir="$(dirname "$manifest")/src"; mkdir -p "$dir"; \
      touch "$dir/lib.rs"; \
      if grep -q '^\[\[bin\]\]' "$manifest"; then echo 'fn main(){}' > "$dir/main.rs"; fi; \
    done

ARG CARGO_PROFILE=release

RUN cargo fetch --locked --target ${TARGET}

# Pre-compile dependencies using stub sources. Compiled rlibs are baked into
# the layer so they persist via BuildKit's layer cache. Cache mounts (the
# previous approach) don't survive across CI runs because each run creates a
# fresh BuildKit daemon; layer caching does survive via type=local export.
RUN --network=none \
    cargo build --frozen --profile ${CARGO_PROFILE} --target ${TARGET} -p eidola-cli

# ── build ──────────────────────────────────────────────────────────────────────
# Copy real source over the stubs and compile (no network access).
# Cargo detects that external dependency rlibs are unchanged and only
# recompiles workspace crates.
FROM fetch AS build

ARG CARGO_PROFILE=release

COPY apps/cli ./apps/cli
COPY crates/ ./crates/

RUN --network=none \
    cargo build --frozen --profile ${CARGO_PROFILE} --target ${TARGET} -p eidola-cli \
    && install -D target/${TARGET}/${CARGO_PROFILE}/eidola /out/eidola

# ── install ────────────────────────────────────────────────────────────────────
# Place binary into /rootfs.
FROM scratch AS install

COPY --from=build /out/eidola /rootfs/eidola

# ── package ────────────────────────────────────────────────────────────────────
# Final minimal image.
FROM scratch AS package

COPY --from=install /rootfs/ /
USER 65534:65534
ENTRYPOINT ["/eidola"]
