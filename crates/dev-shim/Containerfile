# syntax=docker/dockerfile:1@sha256:a7f5ec8c4a35a7f8cd9e6e413f59fd1bfd33f8b623c26981c684f5065dfe3044

FROM rust:1-slim AS build
WORKDIR /src
COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
COPY apps/ ./apps/
COPY crates/ ./crates/
RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    --mount=type=cache,target=/src/target \
    cargo build --release -p dev-shim \
    && install -D target/release/dev-shim /out/dev-shim

FROM debian:bookworm-slim
WORKDIR /src
COPY --from=build /out/dev-shim /usr/local/bin/
EXPOSE 8443
ENTRYPOINT ["dev-shim"]
