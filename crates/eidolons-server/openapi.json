{
  "openapi": "3.1.0",
  "info": {
    "title": "Eidolons API",
    "description": "Privacy-transparent AI proxy API with inline verification metadata",
    "contact": {
      "name": "Mike Marcacci"
    },
    "license": {
      "name": "",
      "identifier": "UNLICENSED"
    },
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "Public"
        ],
        "summary": "Health check endpoint.",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                },
                "example": {
                  "status": "ok"
                }
              }
            }
          }
        }
      }
    },
    "/v1/account": {
      "get": {
        "tags": [
          "Linked"
        ],
        "summary": "GET /v1/account — retrieve account info (authenticated).",
        "operationId": "get_account",
        "responses": {
          "200": {
            "description": "Account info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetAccountResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "basic": []
          }
        ]
      },
      "post": {
        "tags": [
          "Linked"
        ],
        "summary": "POST /v1/account — create a new account.",
        "operationId": "create_account",
        "responses": {
          "201": {
            "description": "Account created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateAccountResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/account/balances": {
      "get": {
        "tags": [
          "Linked"
        ],
        "summary": "GET /v1/account/balances — get credit balance breakdown (authenticated).",
        "operationId": "get_balances",
        "responses": {
          "200": {
            "description": "Balance breakdown",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BalancesResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "basic": []
          }
        ]
      }
    },
    "/v1/account/checkout": {
      "post": {
        "tags": [
          "Linked"
        ],
        "summary": "POST /v1/account/checkout — create a checkout session (authenticated).",
        "description": "Accepts any active Stripe price ID. Automatically determines whether to\ncreate a subscription or one-time payment checkout based on the price type.\nFor subscription prices, enforces the one-active-subscription constraint.",
        "operationId": "create_checkout",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckoutRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Checkout session created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckoutUrlResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Already subscribed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Stripe not configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "basic": []
          }
        ]
      }
    },
    "/v1/account/credentials": {
      "post": {
        "tags": [
          "Linked"
        ],
        "summary": "`POST /v1/account/credentials` — issue anonymous credentials (authenticated).",
        "operationId": "issue_credentials",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IssueCredentialsRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Credential issued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IssueCredentialsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "402": {
            "description": "Insufficient credit balance",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Credential issuance not configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "basic": []
          }
        ]
      }
    },
    "/v1/account/ledger": {
      "get": {
        "tags": [
          "Linked"
        ],
        "summary": "GET /v1/account/ledger — get credit ledger entries (authenticated).",
        "operationId": "get_ledger",
        "responses": {
          "200": {
            "description": "Ledger entries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LedgerResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "basic": []
          }
        ]
      }
    },
    "/v1/account/subscription": {
      "get": {
        "tags": [
          "Linked"
        ],
        "summary": "GET /v1/account/subscription — get subscription details (authenticated).",
        "operationId": "get_subscription",
        "responses": {
          "200": {
            "description": "Subscription details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "No Stripe customer or no subscription",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Stripe not configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "basic": []
          }
        ]
      }
    },
    "/v1/chat/completions": {
      "post": {
        "tags": [
          "Unlinked"
        ],
        "summary": "Create a chat completion.",
        "description": "Requires an ACT (Anonymous Credit Token) for authorization. The spend proof\nis verified, the nullifier is recorded, and a refund token is issued with\nany unspent credits.",
        "operationId": "chat_completions",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatCompletionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Chat completion response with privacy and verification metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EidolonsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "402": {
            "description": "Insufficient charge amount",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Credential already spent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Upstream provider error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/keys": {
      "get": {
        "tags": [
          "Public"
        ],
        "summary": "`GET /v1/keys` — list valid issuer public keys (unauthenticated).",
        "operationId": "list_keys",
        "responses": {
          "200": {
            "description": "Valid issuer public keys",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListKeysResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/models": {
      "get": {
        "tags": [
          "Public"
        ],
        "summary": "List available models.",
        "operationId": "list_models",
        "responses": {
          "200": {
            "description": "List of available models",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelsResponse"
                }
              }
            }
          },
          "502": {
            "description": "Upstream provider error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/prices": {
      "get": {
        "tags": [
          "Public"
        ],
        "summary": "GET /v1/prices — list available prices.",
        "operationId": "list_prices",
        "responses": {
          "200": {
            "description": "List of available prices",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListPricesResponse"
                }
              }
            }
          },
          "503": {
            "description": "Stripe not configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/webhooks/stripe": {
      "post": {
        "tags": [
          "Linked"
        ],
        "summary": "POST /v1/webhooks/stripe",
        "operationId": "stripe_webhook",
        "responses": {
          "200": {
            "description": "Event received"
          },
          "400": {
            "description": "Signature verification failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Webhook secret not configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AssistantMessage": {
        "type": "object",
        "description": "An assistant message in a response.",
        "required": [
          "role"
        ],
        "properties": {
          "content": {
            "type": [
              "string",
              "null"
            ]
          },
          "role": {
            "$ref": "#/components/schemas/Role"
          }
        }
      },
      "AttestationStatus": {
        "type": "string",
        "description": "Attestation status.",
        "enum": [
          "unavailable",
          "verified"
        ]
      },
      "AuthMethod": {
        "type": "string",
        "description": "Supported authorization methods.",
        "enum": [
          "anonymous_credential",
          "none"
        ]
      },
      "AuthorizationInfo": {
        "type": "object",
        "description": "Authorization information.",
        "required": [
          "method",
          "linkable"
        ],
        "properties": {
          "linkable": {
            "type": "boolean",
            "description": "Whether this authorization method allows linking across requests."
          },
          "method": {
            "$ref": "#/components/schemas/AuthMethod",
            "description": "The authorization method used."
          }
        }
      },
      "BackendAttestation": {
        "type": "object",
        "description": "Backend attestation from the inference provider.",
        "required": [
          "provider",
          "signing_address",
          "signature",
          "signed_content",
          "signing_algorithm"
        ],
        "properties": {
          "provider": {
            "type": "string",
            "description": "The provider that issued the attestation (e.g., \"redpill\")."
          },
          "signature": {
            "type": "string",
            "description": "The ECDSA signature over the signed content."
          },
          "signed_content": {
            "type": "string",
            "description": "What was signed: \"sha256(request_body):sha256(response_body)\"."
          },
          "signing_address": {
            "type": "string",
            "description": "The signing address (e.g., Ethereum address for Phala/RedPill)."
          },
          "signing_algorithm": {
            "type": "string",
            "description": "The signing algorithm (e.g., \"ecdsa\")."
          }
        }
      },
      "BalancePool": {
        "type": "object",
        "required": [
          "amount",
          "source"
        ],
        "properties": {
          "amount": {
            "type": "integer",
            "format": "int64"
          },
          "expires_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "source": {
            "type": "string"
          }
        }
      },
      "BalancesResponse": {
        "type": "object",
        "required": [
          "available",
          "pools"
        ],
        "properties": {
          "available": {
            "type": "integer",
            "format": "int64"
          },
          "pools": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BalancePool"
            }
          }
        }
      },
      "ChatCompletionChunk": {
        "type": "object",
        "description": "A streaming chat completion chunk.",
        "required": [
          "id",
          "object",
          "created",
          "model",
          "choices"
        ],
        "properties": {
          "choices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChunkChoice"
            },
            "description": "List of completion choices (deltas)."
          },
          "created": {
            "type": "integer",
            "format": "int64",
            "description": "Unix timestamp of when the chunk was created.",
            "minimum": 0
          },
          "id": {
            "type": "string",
            "description": "Unique identifier for the completion."
          },
          "model": {
            "type": "string",
            "description": "The model used for completion."
          },
          "object": {
            "type": "string",
            "description": "The object type (always \"chat.completion.chunk\")."
          },
          "usage": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Usage",
                "description": "Usage statistics (included in the final chunk by some providers)."
              }
            ]
          }
        }
      },
      "ChatCompletionRequest": {
        "type": "object",
        "description": "A chat completion request.",
        "required": [
          "model",
          "messages"
        ],
        "properties": {
          "max_completion_tokens": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32",
            "description": "The maximum number of completion tokens to generate.",
            "minimum": 0
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Message"
            },
            "description": "A list of messages comprising the conversation."
          },
          "model": {
            "type": "string",
            "description": "ID of the model to use."
          },
          "stop": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/StopSequence",
                "description": "Up to 4 sequences where the API will stop generating."
              }
            ]
          },
          "stream": {
            "type": "boolean",
            "description": "Whether to stream partial responses."
          },
          "temperature": {
            "type": [
              "number",
              "null"
            ],
            "format": "float",
            "description": "Sampling temperature between 0 and 2."
          },
          "top_p": {
            "type": [
              "number",
              "null"
            ],
            "format": "float",
            "description": "Nucleus sampling parameter."
          }
        },
        "additionalProperties": false
      },
      "ChatCompletionResponse": {
        "type": "object",
        "description": "A chat completion response.",
        "required": [
          "id",
          "object",
          "created",
          "model",
          "choices"
        ],
        "properties": {
          "choices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Choice"
            },
            "description": "List of completion choices."
          },
          "created": {
            "type": "integer",
            "format": "int64",
            "description": "Unix timestamp of when the completion was created.",
            "minimum": 0
          },
          "id": {
            "type": "string",
            "description": "Unique identifier for the completion."
          },
          "model": {
            "type": "string",
            "description": "The model used for completion."
          },
          "object": {
            "type": "string",
            "description": "The object type (always \"chat.completion\")."
          },
          "usage": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Usage",
                "description": "Usage statistics for the request."
              }
            ]
          }
        }
      },
      "CheckoutRequest": {
        "type": "object",
        "required": [
          "price_id"
        ],
        "properties": {
          "cancel_url": {
            "type": "string"
          },
          "price_id": {
            "type": "string"
          },
          "success_url": {
            "type": "string"
          }
        }
      },
      "CheckoutUrlResponse": {
        "type": "object",
        "required": [
          "checkout_url"
        ],
        "properties": {
          "checkout_url": {
            "type": "string"
          }
        }
      },
      "Choice": {
        "type": "object",
        "description": "A completion choice.",
        "required": [
          "index",
          "message"
        ],
        "properties": {
          "finish_reason": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/FinishReason",
                "description": "The reason the model stopped generating."
              }
            ]
          },
          "index": {
            "type": "integer",
            "format": "int32",
            "description": "The index of this choice.",
            "minimum": 0
          },
          "message": {
            "$ref": "#/components/schemas/AssistantMessage",
            "description": "The generated message."
          }
        }
      },
      "ChunkChoice": {
        "type": "object",
        "description": "A choice delta in a streaming chunk.",
        "required": [
          "index",
          "delta"
        ],
        "properties": {
          "delta": {
            "$ref": "#/components/schemas/ChunkDelta",
            "description": "The delta (partial update) for this choice."
          },
          "finish_reason": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/FinishReason",
                "description": "The reason the model stopped generating (only in final chunk)."
              }
            ]
          },
          "index": {
            "type": "integer",
            "format": "int32",
            "description": "The index of this choice.",
            "minimum": 0
          }
        }
      },
      "ChunkDelta": {
        "type": "object",
        "description": "A delta update in a streaming response.",
        "properties": {
          "content": {
            "type": [
              "string",
              "null"
            ]
          },
          "role": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Role"
              }
            ]
          }
        }
      },
      "ContentPart": {
        "oneOf": [
          {
            "type": "object",
            "description": "Text content.",
            "required": [
              "text",
              "type"
            ],
            "properties": {
              "text": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "text"
                ]
              }
            }
          },
          {
            "type": "object",
            "description": "Image content via URL.",
            "required": [
              "image_url",
              "type"
            ],
            "properties": {
              "image_url": {
                "$ref": "#/components/schemas/ImageUrl"
              },
              "type": {
                "type": "string",
                "enum": [
                  "image_url"
                ]
              }
            }
          }
        ],
        "description": "A content part within a multimodal message."
      },
      "CreateAccountResponse": {
        "type": "object",
        "required": [
          "account_id",
          "secret",
          "created_at"
        ],
        "properties": {
          "account_id": {
            "type": "string",
            "format": "uuid"
          },
          "created_at": {
            "type": "string"
          },
          "secret": {
            "type": "string"
          }
        }
      },
      "DataExposure": {
        "type": "object",
        "description": "Describes a party's visibility into request/response data.",
        "required": [
          "party",
          "sees",
          "confidentiality",
          "logged"
        ],
        "properties": {
          "confidentiality": {
            "type": "string",
            "description": "How confidentiality is enforced: \"tee\" or \"provider-policy\"."
          },
          "logged": {
            "type": "string",
            "description": "Whether this party logs requests: \"none\", \"unknown\", \"yes\"."
          },
          "party": {
            "type": "string",
            "description": "The party (e.g., \"eidolons-proxy\", \"phala-gpu-tee\", \"anthropic\")."
          },
          "sees": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "What data this party can see (e.g., [\"prompt\", \"response\", \"token_count\"])."
          }
        }
      },
      "EidolonsResponse": {
        "type": "object",
        "description": "An Eidolons chat completion response.",
        "required": [
          "id",
          "object",
          "created",
          "model",
          "choices",
          "privacy",
          "verification"
        ],
        "properties": {
          "choices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Choice"
            },
            "description": "Completion choices."
          },
          "created": {
            "type": "integer",
            "format": "int64",
            "description": "Unix timestamp of when the completion was created.",
            "minimum": 0
          },
          "id": {
            "type": "string",
            "description": "Unique identifier for the completion."
          },
          "model": {
            "type": "string",
            "description": "The model that produced the completion."
          },
          "object": {
            "type": "string",
            "description": "The object type."
          },
          "privacy": {
            "$ref": "#/components/schemas/PrivacyMetadata",
            "description": "Privacy metadata describing data exposure and authorization."
          },
          "refund": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/RefundInfo",
                "description": "Refund token for unspent credits (only present for ACT-authenticated requests)."
              }
            ]
          },
          "usage": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Usage",
                "description": "Token usage statistics."
              }
            ]
          },
          "verification": {
            "$ref": "#/components/schemas/VerificationMetadata",
            "description": "Verification metadata with cryptographic attestations."
          }
        }
      },
      "EidolonsStreamMetadata": {
        "type": "object",
        "description": "Metadata event sent as the final SSE event before [DONE] in streaming responses.\n\nClients identify this by checking `object == \"eidolons.chat.completion.metadata\"`.\nStandard OpenAI clients will ignore it.",
        "required": [
          "object",
          "id",
          "privacy",
          "verification"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "The completion ID this metadata belongs to."
          },
          "object": {
            "type": "string",
            "description": "The object type."
          },
          "privacy": {
            "$ref": "#/components/schemas/PrivacyMetadata",
            "description": "Privacy metadata."
          },
          "refund": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/RefundInfo",
                "description": "Refund token for unspent credits."
              }
            ]
          },
          "verification": {
            "$ref": "#/components/schemas/VerificationMetadata",
            "description": "Verification metadata."
          }
        }
      },
      "ErrorDetail": {
        "type": "object",
        "required": [
          "message",
          "type"
        ],
        "properties": {
          "code": {
            "type": [
              "string",
              "null"
            ]
          },
          "message": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "An error response in OpenAI format, optionally including a refund token.",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorDetail"
          },
          "refund": {
            "description": "Refund token for unspent credits (present when an error occurs after\nthe ACT nullifier has been recorded)."
          }
        }
      },
      "FinishReason": {
        "type": "string",
        "description": "The reason the model stopped generating.",
        "enum": [
          "stop",
          "length",
          "content_filter"
        ]
      },
      "GetAccountResponse": {
        "type": "object",
        "required": [
          "id",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "stripe_customer_id": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "ImageUrl": {
        "type": "object",
        "description": "An image URL reference.",
        "required": [
          "url"
        ],
        "properties": {
          "detail": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional detail level for the image."
          },
          "url": {
            "type": "string",
            "description": "The URL of the image, or a base64-encoded data URI."
          }
        },
        "additionalProperties": false
      },
      "IssueCredentialsRequest": {
        "type": "object",
        "description": "Request body for `POST /v1/account/credentials`.",
        "required": [
          "issuance_request",
          "credits"
        ],
        "properties": {
          "credits": {
            "type": "integer",
            "format": "int64",
            "description": "Number of credits to issue."
          },
          "issuance_request": {
            "type": "string",
            "description": "Base64-encoded CBOR `IssuanceRequest`."
          }
        }
      },
      "IssueCredentialsResponse": {
        "type": "object",
        "description": "Response for `POST /v1/account/credentials`.",
        "required": [
          "issuance_response",
          "issuer_key_id",
          "credits",
          "ledger_entry_id"
        ],
        "properties": {
          "credits": {
            "type": "integer",
            "format": "int64",
            "description": "Number of credits issued."
          },
          "issuance_response": {
            "type": "string",
            "description": "Base64-encoded CBOR `IssuanceResponse`."
          },
          "issuer_key_id": {
            "type": "string",
            "description": "Issuer key identifier: hex-encoded SHA-256(pkI_serialized)."
          },
          "ledger_entry_id": {
            "type": "string",
            "description": "The ledger entry ID for this issuance."
          }
        }
      },
      "IssuerKeyResponse": {
        "type": "object",
        "description": "A single issuer public key in the `GET /v1/keys` response.",
        "required": [
          "id",
          "public_key",
          "domain_separator",
          "issue_from",
          "issue_until",
          "accept_until"
        ],
        "properties": {
          "accept_until": {
            "type": "string",
            "description": "End of the acceptance window (ISO 8601)."
          },
          "domain_separator": {
            "type": "string",
            "description": "Domain separator used for parameter generation."
          },
          "id": {
            "type": "string",
            "description": "Issuer key ID: hex-encoded SHA-256(pkI_serialized)."
          },
          "issue_from": {
            "type": "string",
            "description": "Start of the issuance window (ISO 8601)."
          },
          "issue_until": {
            "type": "string",
            "description": "End of the issuance window (ISO 8601)."
          },
          "public_key": {
            "type": "string",
            "description": "Base64url-encoded CBOR public key (compressed Ristretto255 point)."
          }
        }
      },
      "LedgerEntry": {
        "type": "object",
        "required": [
          "id",
          "delta",
          "reason",
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string"
          },
          "credential_credits": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "credential_key_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "delta": {
            "type": "integer",
            "format": "int64"
          },
          "expires_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "LedgerResponse": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LedgerEntry"
            }
          }
        }
      },
      "ListKeysResponse": {
        "type": "object",
        "description": "Response for `GET /v1/keys`.",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IssuerKeyResponse"
            }
          }
        }
      },
      "ListPricesResponse": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PriceResponse"
            }
          }
        }
      },
      "Message": {
        "type": "object",
        "description": "A message in the conversation.",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "content": {
            "$ref": "#/components/schemas/MessageContent",
            "description": "The content of the message."
          },
          "name": {
            "type": [
              "string",
              "null"
            ],
            "description": "An optional name for the participant."
          },
          "role": {
            "$ref": "#/components/schemas/Role",
            "description": "The role of the message author."
          }
        },
        "additionalProperties": false
      },
      "MessageContent": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContentPart"
            }
          }
        ],
        "description": "Message content can be a simple string or array of content parts (for multimodal)."
      },
      "Model": {
        "type": "object",
        "description": "A model descriptor.",
        "required": [
          "id",
          "name",
          "description",
          "context_length",
          "pricing"
        ],
        "properties": {
          "context_length": {
            "type": "integer",
            "format": "int64",
            "description": "Maximum context window size in tokens.",
            "minimum": 0
          },
          "description": {
            "type": "string",
            "description": "Short description of the model's capabilities."
          },
          "id": {
            "type": "string",
            "description": "The model identifier (e.g. \"openai/gpt-4o\")."
          },
          "name": {
            "type": "string",
            "description": "Human-readable display name."
          },
          "pricing": {
            "$ref": "#/components/schemas/ModelPricing",
            "description": "Pricing in integer credits per 1k tokens."
          }
        }
      },
      "ModelPricing": {
        "type": "object",
        "description": "Pricing for a model in scaled integer credits per token.",
        "required": [
          "per_prompt_token",
          "per_completion_token"
        ],
        "properties": {
          "per_completion_token": {
            "$ref": "#/components/schemas/ScaledPrice"
          },
          "per_prompt_token": {
            "$ref": "#/components/schemas/ScaledPrice"
          }
        }
      },
      "ModelsResponse": {
        "type": "object",
        "description": "A list of available models.",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Model"
            },
            "description": "The list of models."
          }
        }
      },
      "PriceResponse": {
        "type": "object",
        "required": [
          "id",
          "product_name",
          "currency",
          "type",
          "credits"
        ],
        "properties": {
          "credits": {
            "type": "integer",
            "format": "int64"
          },
          "currency": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "lookup_key": {
            "type": [
              "string",
              "null"
            ]
          },
          "product_description": {
            "type": [
              "string",
              "null"
            ]
          },
          "product_name": {
            "type": "string"
          },
          "recurring": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/RecurringResponse"
              }
            ]
          },
          "type": {
            "type": "string"
          },
          "unit_amount": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          }
        }
      },
      "PrivacyMetadata": {
        "type": "object",
        "description": "Privacy metadata describing how the request was authorized, what data is\nvisible to which parties, and transport security properties.",
        "required": [
          "authorization",
          "data_exposure",
          "transport"
        ],
        "properties": {
          "authorization": {
            "$ref": "#/components/schemas/AuthorizationInfo",
            "description": "Authorization details."
          },
          "data_exposure": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DataExposure"
            },
            "description": "Which parties can see which data, and under what guarantees."
          },
          "transport": {
            "$ref": "#/components/schemas/TransportInfo",
            "description": "Transport security between hops."
          }
        }
      },
      "ProxyAttestation": {
        "type": "object",
        "description": "Proxy attestation (placeholder for future TEE deployment).",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "$ref": "#/components/schemas/AttestationStatus",
            "description": "Current attestation status."
          }
        }
      },
      "RecurringResponse": {
        "type": "object",
        "required": [
          "interval",
          "interval_count"
        ],
        "properties": {
          "interval": {
            "type": "string"
          },
          "interval_count": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "RefundInfo": {
        "type": "object",
        "description": "A refund token issued after spending an ACT.",
        "required": [
          "refund",
          "issuer_key_id"
        ],
        "properties": {
          "issuer_key_id": {
            "type": "string",
            "description": "The issuer key ID that signed this refund."
          },
          "refund": {
            "type": "string",
            "description": "Base64url-encoded CBOR `Refund` message."
          }
        }
      },
      "Role": {
        "type": "string",
        "description": "The role of a message author.",
        "enum": [
          "system",
          "user",
          "assistant"
        ]
      },
      "ScaledPrice": {
        "type": "object",
        "description": "A price expressed as an integer value with a fixed scale factor.\n\nActual credits per unit = `value / scale_factor`.",
        "required": [
          "value",
          "scale_factor"
        ],
        "properties": {
          "scale_factor": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "value": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      },
      "StopSequence": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ],
        "description": "Stop sequence can be a single string or array of strings."
      },
      "SubscriptionResponse": {
        "type": "object",
        "required": [
          "id",
          "status",
          "management_url"
        ],
        "properties": {
          "current_period_end": {
            "type": [
              "string",
              "null"
            ]
          },
          "id": {
            "type": "string"
          },
          "management_url": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "TransportInfo": {
        "type": "object",
        "description": "Transport security information.",
        "required": [
          "client_to_proxy",
          "proxy_to_backend"
        ],
        "properties": {
          "client_to_proxy": {
            "type": "string",
            "description": "Transport from client to this proxy."
          },
          "proxy_to_backend": {
            "type": "string",
            "description": "Transport from this proxy to the backend."
          }
        }
      },
      "Usage": {
        "type": "object",
        "description": "Token usage statistics.",
        "required": [
          "prompt_tokens",
          "completion_tokens",
          "total_tokens"
        ],
        "properties": {
          "completion_tokens": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "prompt_tokens": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "total_tokens": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "VerificationMetadata": {
        "type": "object",
        "description": "Verification metadata with cryptographic attestations for the proxy and backend.",
        "properties": {
          "backend": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/BackendAttestation",
                "description": "Backend attestation (only for TEE-backed models like phala/*)."
              }
            ]
          },
          "proxy": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ProxyAttestation",
                "description": "Proxy attestation (None until the proxy runs in a TEE)."
              }
            ]
          }
        }
      }
    },
    "securitySchemes": {
      "basic": {
        "type": "http",
        "scheme": "basic",
        "description": "Account credentials. Username is the account UUID, password is the secret returned at account creation."
      }
    }
  },
  "tags": [
    {
      "name": "Public",
      "description": "Unauthenticated endpoints available to anyone."
    },
    {
      "name": "Linked",
      "description": "Authenticated endpoints tied to a known account (HTTP Basic auth)."
    },
    {
      "name": "Unlinked",
      "description": "Endpoints authenticated with anonymous credentials — usage cannot be linked back to an account."
    }
  ]
}
