# syntax=docker/dockerfile:1

# ── base ───────────────────────────────────────────────────────────────────────
# Environment variables, pinned toolchain digest.
FROM stagex/pallet-rust@sha256:4062550919db682ebaeea07661551b5b89b3921e3f3a2b0bc665ddea7f6af1ca AS base

ENV TARGET=x86_64-unknown-linux-musl
ENV RUSTFLAGS="-C target-feature=+crt-static"

WORKDIR /src

# ── fetch ──────────────────────────────────────────────────────────────────────
# Copy source and download dependencies (network access required).
FROM base AS fetch

COPY Cargo.toml Cargo.lock rust-toolchain.toml ./
COPY crates/ ./crates/
COPY tools/ ./tools/

RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    cargo fetch --locked --target ${TARGET}

# ── build ──────────────────────────────────────────────────────────────────────
# Compile sources (no network access).
# Cache mounts persist the cargo registry and target dir across builds without
# affecting the final image. The binary is copied to /out because cache mounts
# are only available during RUN, not COPY.
FROM fetch AS build

RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    --mount=type=cache,target=/src/target \
    --network=none \
    cargo build --frozen --release --target ${TARGET} -p eidolons-server \
    && install -D target/${TARGET}/release/eidolons-server /out/eidolons-server

# ── install ────────────────────────────────────────────────────────────────────
# Place binary into /rootfs.
FROM scratch AS install

COPY --from=build /out/eidolons-server /rootfs/eidolons-server

# ── package ────────────────────────────────────────────────────────────────────
# Final minimal image.
FROM scratch AS package

COPY --from=install /rootfs/ /
ENV BIND_ADDR=0.0.0.0:8080
EXPOSE 8080
USER 65534:65534
ENTRYPOINT ["/eidolons-server"]
