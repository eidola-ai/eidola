{
  "markdown": "# Heading\n\nbody",
  "size": [800, 200],
  "outDir": "/tmp/markdown-audit-heading-backspace",
  "injection": "sendEvent",
  "stepDelayMs": 60,
  "events": [
    { "type": "snapshot", "name": "step-00-initial" },
    { "type": "set_cursor", "position": 2 },
    { "type": "wait", "ms": 50 },
    { "type": "snapshot", "name": "step-01-cursor-at-text-start" },
    { "type": "key", "name": "backspace" },
    { "type": "snapshot", "name": "step-02-after-backspace" }
  ]
}
