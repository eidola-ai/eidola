{
  "markdown": "A **B** C D E",
  "size": [800, 200],
  "outDir": "/tmp/markdown-audit-shift-arrow-reversal",
  "injection": "sendEvent",
  "stepDelayMs": 60,
  "events": [
    { "type": "snapshot", "name": "step-00-initial" },
    { "type": "set_cursor", "position": 4 },
    { "type": "wait", "ms": 50 },
    { "type": "snapshot", "name": "step-01-cursor-at-B" },
    { "type": "key", "name": "shift+right" },
    { "type": "snapshot", "name": "step-02-shift-right-1" },
    { "type": "key", "name": "shift+right" },
    { "type": "snapshot", "name": "step-03-shift-right-2" },
    { "type": "key", "name": "shift+left" },
    { "type": "snapshot", "name": "step-04-shift-left-1" },
    { "type": "key", "name": "shift+left" },
    { "type": "snapshot", "name": "step-05-shift-left-2-back-to-cursor" }
  ]
}
