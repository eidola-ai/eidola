# Mark generated Swift bindings as generated code
# This collapses them in GitHub PR diffs and marks them in GitHub's UI

# Core library (eidolons/) Swift bindings
eidolons/swift/Sources/EidolonsCore/*.swift linguist-generated=true
eidolons/swift/Sources/EidolonsCoreFFI/*.h linguist-generated=true
eidolons/swift/Sources/EidolonsCoreFFI/*.c linguist-generated=true
eidolons/swift/Sources/EidolonsCoreFFI/*.modulemap linguist-generated=true

# Shared core (eidolons-shared/) Swift bindings - UniFFI
crates/eidolons-shared/swift/Sources/EidolonsShared/*.swift linguist-generated=true
crates/eidolons-shared/swift/Sources/EidolonsSharedFFI/*.h linguist-generated=true
crates/eidolons-shared/swift/Sources/EidolonsSharedFFI/*.c linguist-generated=true
crates/eidolons-shared/swift/Sources/EidolonsSharedFFI/*.modulemap linguist-generated=true

# Shared core (eidolons-shared/) Swift bindings - Crux TypeGen
crates/eidolons-shared/swift/generated/SharedTypes/Sources/SharedTypes/*.swift linguist-generated=true
crates/eidolons-shared/swift/generated/SharedTypes/Sources/Serde/*.swift linguist-generated=true

# Server OpenAPI spec
eidolons-server/openapi.json linguist-generated=true
